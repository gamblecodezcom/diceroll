# Required
BOT_TOKEN=123456:ABC-DEF...

# --- Transport: webhook (primary) or polling ---
# If WEBHOOK_URL (or WEBHOOK_BASE_URL) is set and USE_POLLING is not true → webhook mode.
# Telegram requires HTTPS on the public URL (terminate TLS at nginx/Caddy; bot listens HTTP on PORT).

# Full URL Telegram will POST to (must match your reverse proxy path):
# WEBHOOK_URL=https://your.domain/telegram/webhook

# Or split:
# WEBHOOK_BASE_URL=https://your.domain
# WEBHOOK_PATH=telegram/webhook

# Optional secret (Telegram sends X-Telegram-Bot-Api-Secret-Token)
# WEBHOOK_SECRET=random_long_string

# Force long polling even if WEBHOOK_URL is set (dev / tunnel issues)
# USE_POLLING=true

# HTTP server: webhook mode uses this port for Flask/PTB (no second keep_alive thread).
# Polling mode: keep_alive + polling share PORT.
# PORT=8080
# BIND=0.0.0.0

# BOT_USERNAME=YourBot
# BOT_ADMINS=123,456
# RESTRICT_ROLL_COMMANDS=true
