# Required: token from @BotFather (use a dedicated bot or same token only if not shared with Node)
BOT_TOKEN=123456:ABC-DEF...

# Optional: comma-separated user IDs — always allowed for host commands when restriction is on
# BOT_ADMINS=123456789,987654321

# Only chat admins (+ BOT_ADMINS) may /create_roll and /abort_roll in groups
# Legacy name RESTRICT_HUNT_COMMANDS is also accepted
# RESTRICT_ROLL_COMMANDS=true

# HTTP keep-alive (use a free port on your VPS if Node already uses 8080)
# PORT=8090
# BIND=0.0.0.0

# Optional fallback if bot username is not available at startup
# BOT_USERNAME=YourBotName
