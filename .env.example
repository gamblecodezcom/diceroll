# Your main bot already uses TELEGRAM_BOT_TOKEN — same variable.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Optional: for t.me/... deep links if bot username not on ctx yet
# TELEGRAM_BOT_USERNAME=YourBotName
# BOT_USERNAME=YourBotName

# Optional: comma-separated Telegram user IDs (always allowed for host commands when restricted)
# BOT_ADMINS=123456789,987654321

# Optional: only group admins (+ BOT_ADMINS) may /create_roll, /abort_roll when "true"
# RESTRICT_ROLL_COMMANDS=true
# RESTRICT_HUNT_COMMANDS=true
